{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/dotfiles/scripts/misc/codex-tmux-sidebar-hook\" codex activity-log'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/dotfiles/scripts/misc/codex-tmux-sidebar-hook\" codex session-start'",
            "type": "command"
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/dotfiles/scripts/misc/codex-tmux-sidebar-hook\" codex stop'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash -lc 'exec \"$HOME/dotfiles/scripts/misc/codex-tmux-sidebar-hook\" codex user-prompt-submit'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
