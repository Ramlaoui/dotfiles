#!/usr/bin/env bash
set -u

plugin_hook="${TMUX_AGENT_SIDEBAR_HOOK:-$HOME/.config/tmux/plugins/tmux-agent-sidebar/hook.sh}"
state_dir="${CODEX_TMUX_SIDEBAR_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/codex-tmux-sidebar}"
pending_file="$state_dir/pending.json"
sessions_file="$state_dir/sessions.json"
lock_dir="$state_dir/lock.d"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
pending_max_age_seconds="${CODEX_TMUX_SIDEBAR_PENDING_MAX_AGE_SECONDS:-600}"

# shellcheck source=scripts/misc/codex-tmux-sidebar-lock
. "$script_dir/codex-tmux-sidebar-lock"

agent_name="${1:-}"
event_name="${2:-}"
input="$(cat)"

[[ -f "$plugin_hook" ]] || exit 0

pane_exists() {
  [[ -n "$1" ]] && command -v tmux >/dev/null 2>&1 && tmux display-message -p -t "$1" "#{pane_id}" >/dev/null 2>&1
}

pane_claimable_for_session() {
  local target="$1"
  local current_agent current_session

  pane_exists "$target" || return 1
  current_agent="$(tmux show-options -pt "$target" -v @pane_agent 2>/dev/null || true)"
  current_session="$(tmux show-options -pt "$target" -v @pane_session_id 2>/dev/null || true)"

  # Same-cwd Codex launches can overlap. Do not let a new session claim a
  # pane that tmux-agent-sidebar already knows belongs to another Codex run.
  [[ -z "$current_agent" || "$current_agent" != "codex" || -z "$current_session" || "$current_session" == "$session_id" ]]
}

json_field() {
  local query="$1"
  command -v jq >/dev/null 2>&1 || return 0
  jq -r "$query // empty" 2>/dev/null <<<"$input"
}

init_state_files() {
  mkdir -p "$state_dir"
  [[ -s "$pending_file" ]] || printf '[]\n' > "$pending_file"
  [[ -s "$sessions_file" ]] || printf '{}\n' > "$sessions_file"
}

claim_pending_for_session() {
  [[ -n "$session_id" && -n "$cwd" ]] || return 0

  local rows row token candidate tmp
  rows="$(
    jq -r \
      --arg cwd "$cwd" \
      --argjson now "$now" \
      --argjson max_age "$pending_max_age_seconds" \
      '[.[] | select(.cwd == $cwd and (($now - (.created_at // 0)) < $max_age))]
       | reverse[]
       | [.token, .pane]
       | @tsv' \
      "$pending_file" 2>/dev/null
  )"

  while IFS= read -r row; do
    [[ -n "$row" ]] || continue
    token="${row%%$'\t'*}"
    candidate="${row#*$'\t'}"
    if pane_claimable_for_session "$candidate"; then
      pane="$candidate"

      if [[ -n "$session_id" ]]; then
        tmp="$(mktemp "$state_dir/sessions.XXXXXX")"
        jq \
          --arg sid "$session_id" \
          --arg pane "$pane" \
          --arg cwd "$cwd" \
          --argjson now "$now" \
          '.[$sid] = {pane: $pane, cwd: $cwd, updated_at: $now}' \
          "$sessions_file" > "$tmp"
        mv "$tmp" "$sessions_file"
      fi

      tmp="$(mktemp "$state_dir/pending.XXXXXX")"
      jq \
        --arg token "$token" \
        --arg pane "$pane" \
        --argjson now "$now" \
        --argjson max_age "$pending_max_age_seconds" \
        '[.[] | select(.token != $token and .pane != $pane and (($now - (.created_at // 0)) < $max_age))]' \
        "$pending_file" > "$tmp"
      mv "$tmp" "$pending_file"
      return 0
    fi
  done <<<"$rows"
}

resolve_session_pane() {
  [[ -n "$session_id" ]] || return 0

  local candidate tmp
  candidate="$(jq -r --arg sid "$session_id" '.[$sid].pane // empty' "$sessions_file" 2>/dev/null)"
  if pane_exists "$candidate"; then
    pane="$candidate"
    return 0
  fi

  if [[ -n "$candidate" ]]; then
    tmp="$(mktemp "$state_dir/sessions.XXXXXX")"
    jq --arg sid "$session_id" 'del(.[$sid])' "$sessions_file" > "$tmp"
    mv "$tmp" "$sessions_file"
  fi
}

session_id="$(json_field '.session_id // .sessionId')"
cwd="$(json_field '.cwd')"
now="$(date +%s)"
pane=""

if command -v jq >/dev/null 2>&1; then
  init_state_files
  if codex_tmux_sidebar_acquire_lock; then
    claim_pending_for_session
    [[ -n "$pane" ]] || resolve_session_pane
    codex_tmux_sidebar_release_lock
  fi
fi

if [[ -n "$pane" ]]; then
  TMUX_PANE="$pane" bash "$plugin_hook" "$agent_name" "$event_name" <<<"$input"
else
  bash "$plugin_hook" "$agent_name" "$event_name" <<<"$input"
fi
