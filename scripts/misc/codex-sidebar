#!/usr/bin/env bash
set -euo pipefail

state_dir="${CODEX_TMUX_SIDEBAR_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/codex-tmux-sidebar}"
pending_file="$state_dir/pending.json"
lock_dir="$state_dir/lock.d"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=scripts/misc/codex-tmux-sidebar-lock
. "$script_dir/codex-tmux-sidebar-lock"

update_pending_file() {
  local cwd now token tmp
  cwd="$(pwd -P 2>/dev/null || pwd)"
  now="$(date +%s)"
  token="$$:$now:${RANDOM:-0}"
  tmp="$(mktemp "$state_dir/pending.XXXXXX")"

  if jq \
    --arg token "$token" \
    --arg pane "$TMUX_PANE" \
    --arg cwd "$cwd" \
    --argjson now "$now" \
    '[.[] | select(($now - (.created_at // 0)) < 3600)]
     + [{token: $token, pane: $pane, cwd: $cwd, created_at: $now}]' \
    "$pending_file" > "$tmp"; then
    mv "$tmp" "$pending_file"
  else
    rm -f "$tmp"
    return 1
  fi
}

record_pending_launch() {
  command -v jq >/dev/null 2>&1 || return 0
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || return 0

  mkdir -p "$state_dir"
  [[ -s "$pending_file" ]] || printf '[]\n' > "$pending_file"

  if codex_tmux_sidebar_acquire_lock; then
    update_pending_file || true
    codex_tmux_sidebar_release_lock
  fi
}

record_pending_launch
exec codex "$@"
