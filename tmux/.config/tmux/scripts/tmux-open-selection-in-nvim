#!/usr/bin/env bash
set -euo pipefail

die() {
  printf 'tmux-open-selection-in-nvim: %s\n' "$*" >&2
  tmux display-message "tmux-open-selection-in-nvim: $*" 2>/dev/null || true
  exit 1
}

trim_selection() {
  sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

strip_wrapping_quote() {
  local value="$1"
  local first="${value:0:1}"
  local last="${value: -1}"

  case "$first$last" in
    "''" | '""' | '``') printf '%s\n' "${value:1:${#value}-2}" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

resolve_path() {
  local cwd="$1"
  local selected_path="$2"

  case "$selected_path" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${selected_path#~/}" ;;
    /*) printf '%s\n' "$selected_path" ;;
    *) printf '%s/%s\n' "$cwd" "$selected_path" ;;
  esac
}

path_with_cursor() {
  local target="$1"

  if [[ "$target" =~ ^(.+):([0-9]+):([0-9]+):?$ ]]; then
    printf '%s\t%s\t%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}"
  elif [[ "$target" =~ ^(.+):([0-9]+):?$ ]]; then
    printf '%s\t%s\t\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
  else
    printf '%s\t\t\n' "$target"
  fi
}

window_name_for() {
  local target="$1"
  local name

  name="$(basename "$target")"
  [[ -n "$name" && "$name" != "/" ]] || name="nvim"
  name="nvim:${name}"
  name="${name//$'\t'/ }"
  name="${name//$'\n'/ }"
  printf '%s\n' "${name:0:48}"
}

pane_cwd="${1:-$PWD}"
target_session="${2:-}"
command -v nvim >/dev/null 2>&1 || die "missing required command: nvim"

[[ -d "$pane_cwd" ]] || die "pane cwd does not exist: $pane_cwd"
pane_cwd="$(cd "$pane_cwd" && pwd -P)"

selection="$(trim_selection)"
selection="${selection//$'\r'/}"
[[ -n "$selection" ]] || die "selection is empty"
[[ "$selection" != *$'\n'* ]] || die "selection must be a single path"

selection="$(strip_wrapping_quote "$selection")"

if [[ "$selection" =~ ^[A-Za-z][A-Za-z0-9+.-]*:// ]]; then
  die "selection is a URL, not a local path"
fi

IFS=$'\t' read -r selected_path line column < <(path_with_cursor "$selection")
[[ -n "$selected_path" ]] || die "selection is empty"

resolved_path="$(resolve_path "$pane_cwd" "$selected_path")"

if [[ -d "$resolved_path" ]]; then
  workdir="$(cd "$resolved_path" && pwd -P)"
  nvim_target="$workdir"
elif [[ -e "$resolved_path" ]]; then
  workdir="$(cd "$(dirname "$resolved_path")" && pwd -P)"
  nvim_target="$workdir/$(basename "$resolved_path")"
else
  parent="$(dirname "$resolved_path")"
  [[ -d "$parent" ]] || die "parent directory does not exist: $parent"
  workdir="$(cd "$parent" && pwd -P)"
  nvim_target="$workdir/$(basename "$resolved_path")"
fi

printf -v target_arg '%q' "$nvim_target"
nvim_command="nvim"
if [[ -n "$line" && -n "$column" ]]; then
  cursor_command="+call cursor($line, $column)"
  printf -v cursor_arg '%q' "$cursor_command"
  nvim_command+=" $cursor_arg"
elif [[ -n "$line" ]]; then
  nvim_command+=" +$line"
fi
nvim_command+=" -- $target_arg"

tmux_args=(new-window -c "$workdir" -n "$(window_name_for "$nvim_target")")
if [[ -n "$target_session" ]]; then
  tmux_args+=(-t "${target_session}:")
fi
tmux_args+=("$nvim_command")

if [[ "${TMUX_OPEN_SELECTION_DRY_RUN:-}" == 1 ]]; then
  printf 'workdir=%s\n' "$workdir"
  printf 'target=%s\n' "$nvim_target"
  printf 'command=%s\n' "$nvim_command"
  printf 'tmux_args='
  printf '%q ' "${tmux_args[@]}"
  printf '\n'
  exit 0
fi

tmux "${tmux_args[@]}"
