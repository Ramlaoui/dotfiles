# Tmux helpers
function tsplit() {
  tmux split-window -v "$@"
}

function tvsplit() {
  tmux split-window -h "$@"
}

function tresize() {
  tmux resize-pane -D "$@"
}

function tresizeh() {
  tmux resize-pane -R "$@"
}

function tresizev() {
  tmux resize-pane -U "$@"
}

function tresizeleft() {
  tmux resize-pane -L "$@"
}

function tresizeup() {
  tmux resize-pane -U "$@"
}

function tresizedown() {
  tmux resize-pane -D "$@"
}

function tresizeright() {
  tmux resize-pane -R "$@"
}

# Rsync helpers
function rsync () {
    if [ -f "$XDG_CONFIG_HOME/rsync/.rsync.exclude" ]; then
        set -- --exclude-from="$XDG_CONFIG_HOME/rsync/.rsync.exclude" "$@"
    fi

    command rsync "$@"
}

function rsyncgit () {
    if [ -f "$XDG_CONFIG_HOME/rsync/.rsync.exclude" ]; then
        set -- --exclude-from="$XDG_CONFIG_HOME/rsync/.rsync.exclude" --filter=':- .gitignore' "$@"
    fi

    command rsync "$@"
}

if [ -f "${HOME}/dotfiles/zsh/.config/zsh/ccs_vscode_functions.zsh" ]; then
    source "${HOME}/dotfiles/zsh/.config/zsh/ccs_vscode_functions.zsh"
fi
