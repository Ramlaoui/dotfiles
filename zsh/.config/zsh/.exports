#!/usr/bin/env bash

# Set XDG Base Directories
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:=$HOME/.config}"
export XDG_DATA_HOME="$HOME/.local/share"

# Set NPM prefix
export NPM_CONFIG_PREFIX="$XDG_DATA_HOME/node"

# Set Bun prefix
export BUN_INSTALL="$HOME/.bun"

# Set PATH
export PATH="$BUN_INSTALL/bin:$XDG_CONFIG_HOME/emacs/bin:$HOME/.local/bin:$XDG_DATA_HOME/node/bin:$PATH"

# neovim as default editor
export EDITOR=nvim
export VISUAL=nvim
export MANPAGER='nvim --cmd ":lua vim.g.noplugins=1" +Man!'
export MANWIDTH=999

# Emacs as default editor
# export ALTERNATE_EDITOR=""
# export EDITOR="emacsclient -t"                  # $EDITOR opens in terminal
# export VISUAL="emacsclient -c -a emacs"         # $VISUAL opens in GUI mode

# Set fuzzy finder
export CM_LAUNCHER="fzf"

# Python REPL for vi editing mode on new versions
export PYTHON_BASIC_REPL=1
export IPYTHONDIR="$XDG_CONFIG_HOME/ipython"
export PYTHONBREAKPOINT=ipdb.set_trace

# GO
export GOPATH="$HOME/.local/go"
export GOROOT="$HOME/.local/go"
export PATH="$GOPATH/bin:$PATH"

# Folders
export ICLOUD="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
export ADMIN="$ICLOUD/admin"

# Git signing
if tty -s; then
    export GPG_TTY="$(tty)"
    command -v gpg-connect-agent >/dev/null && gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1
fi

# Other
export SCRATCH="/network/scratch/a/ali.ramlaoui/"
# export GOOGLE_APPLICATION_CREDENTIALS="$HOME/.config/gcloud/credentials.json"
